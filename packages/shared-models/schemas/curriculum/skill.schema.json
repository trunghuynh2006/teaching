{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill",
  "description": "A skill that groups lessons students need to complete.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique skill identifier."
    },
    "title": {
      "type": "string",
      "description": "Skill title."
    },
    "description": {
      "type": "string",
      "description": "Short skill description."
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ],
      "default": "beginner",
      "description": "Relative skill difficulty level."
    },
    "status": {
      "type": "string",
      "enum": [
        "published",
        "archived",
        "draft"
      ],
      "default": "draft",
      "description": "Skill lifecycle status."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Skill tags."
    },
    "created_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": [
    "id",
    "title"
  ]
}
