{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson",
  "description": "Shared lesson model for frontend and backend.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique lesson identifier."
    },
    "concept_id": {
      "type": ["string", "null"],
      "default": null,
      "description": "The concept this learning unit teaches."
    },
    "source_id": {
      "type": ["string", "null"],
      "default": null,
      "description": "The source (Knowledge) this unit was generated from or linked to."
    },
    "type": {
      "type": "string",
      "enum": ["lesson", "quiz", "flashcard", "video"],
      "default": "lesson",
      "description": "Learning unit type."
    },
    "difficulty": {
      "type": ["string", "null"],
      "enum": ["beginner", "intermediate", "advanced", null],
      "default": null,
      "description": "Difficulty level."
    },
    "title": {
      "type": "string",
      "description": "Lesson title."
    },
    "description": {
      "type": "string",
      "description": "Short lesson description."
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Estimated duration in minutes."
    },
    "is_published": {
      "type": "boolean",
      "default": false,
      "description": "Publishing state."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Lesson tags."
    },
    "created_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": [
    "id",
    "title"
  ]
}
