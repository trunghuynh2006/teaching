{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Topic",
  "description": "A subject area grouping related concepts.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique topic identifier."
    },
    "name": {
      "type": "string",
      "description": "Topic name."
    },
    "folder_id": {
      "type": "string",
      "description": "The folder this topic belongs to."
    },
    "concept_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Ordered list of concept identifiers belonging to this topic."
    },
    "description": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional description of the topic."
    },
    "created_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": ["id", "name", "folder_id"]
}
