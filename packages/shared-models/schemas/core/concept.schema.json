{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Concept",
  "description": "A small, digestible unit of knowledge within a topic.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique concept identifier."
    },
    "canonical_name": {
      "type": "string",
      "description": "The canonical name of the concept."
    },
    "domain": {
      "type": ["string", "null"],
      "default": null,
      "description": "Subject domain or namespace (e.g. physics, linguistics). Prevents ambiguous deduplication across fields."
    },
    "description": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional description of the concept."
    },
    "created_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": ["id", "canonical_name"]
}
