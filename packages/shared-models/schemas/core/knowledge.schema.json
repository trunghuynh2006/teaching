{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge",
  "description": "A text-based piece of content belonging to a folder.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique knowledge identifier."
    },
    "folder_id": {
      "type": "string",
      "description": "The folder this knowledge belongs to."
    },
    "title": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional title or heading."
    },
    "content": {
      "type": "string",
      "description": "The main text content."
    },
    "created_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": ["id", "folder_id", "content"]
}
