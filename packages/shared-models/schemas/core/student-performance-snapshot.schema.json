{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StudentPerformanceSnapshot",
  "description": "Immutable point-in-time snapshot of learner performance for a skill.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique snapshot identifier."
    },
    "student_performance_id": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Referenced student performance rollup identifier, if available."
    },
    "learner_id": {
      "type": "string",
      "format": "uuid",
      "description": "Referenced learner (student profile) identifier."
    },
    "skill_id": {
      "type": "string",
      "description": "Referenced skill identifier."
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Observed normalized performance score in range 0-100."
    },
    "level_framework": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Optional proficiency framework identifier at this snapshot (for example cefr)."
    },
    "level_value": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Optional level value within the selected framework at this snapshot (for example B2)."
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this performance snapshot was recorded (ISO 8601)."
    },
    "source": {
      "type": "string",
      "enum": [
        "assessment",
        "assignment",
        "manual",
        "system"
      ],
      "default": "system",
      "description": "Source of this measurement."
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Optional notes about the snapshot."
    },
    "created_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "default": null,
      "description": "User identifier that created this snapshot."
    },
    "created_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null,
      "description": "Snapshot creation timestamp (ISO 8601)."
    }
  },
  "required": [
    "id",
    "learner_id",
    "skill_id",
    "score",
    "recorded_at"
  ]
}
