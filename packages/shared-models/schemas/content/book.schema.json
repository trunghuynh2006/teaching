{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Book",
  "description": "A book linked 1-to-1 with a Source entry.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique book identifier."
    },
    "source_id": {
      "type": "string",
      "description": "The Source entry this book extends (unique)."
    },
    "author": {
      "type": ["string", "null"],
      "default": null,
      "description": "Author name."
    },
    "isbn": {
      "type": ["string", "null"],
      "default": null,
      "description": "ISBN identifier."
    },
    "published_at": {
      "type": ["string", "null"],
      "default": null,
      "description": "Publication date (ISO 8601)."
    },
    "created_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": ["id", "source_id"]
}
