{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source",
  "description": "A piece of content — text, PDF, audio, video, or article — belonging to a folder.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique knowledge identifier."
    },
    "folder_id": {
      "type": "string",
      "description": "The folder this knowledge belongs to."
    },
    "type": {
      "type": "string",
      "enum": ["text", "pdf", "audio", "video", "article"],
      "default": "text",
      "description": "Content type of the source."
    },
    "file_url": {
      "type": ["string", "null"],
      "default": null,
      "description": "URL to the uploaded file (non-text sources)."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "processing", "processed", "failed"],
      "default": "draft",
      "description": "Processing status of the source content."
    },
    "title": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional title or heading."
    },
    "content": {
      "type": "string",
      "description": "The main text content."
    },
    "created_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that created this record."
    },
    "updated_by": {
      "type": ["string", "null"],
      "default": null,
      "description": "User identifier that last updated this record."
    },
    "created_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record creation timestamp (ISO 8601)."
    },
    "updated_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Record update timestamp (ISO 8601)."
    }
  },
  "required": ["id", "folder_id", "content"]
}
